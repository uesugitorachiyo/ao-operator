def log_event(invocation_id: str, name: str, payload) -> None:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    path = LOG_DIR / f"{invocation_id}-{name}"
    if isinstance(payload, (dict, list)):
        path.write_text(json.dumps(payload, indent=2, sort_keys=True))
    else:
        path.write_text(str(payload))


def extract_json_object(text: str) -> str:
    """Pull the first balanced JSON object out of ``text``.

    Tolerates ```json fences, leading/trailing prose, and stray newlines.
    """

    stripped = text.strip()
    # Strip ```json … ``` fences if present.
    if stripped.startswith("```"):
        stripped = stripped.split("\n", 1)[1] if "\n" in stripped else stripped
        if stripped.endswith("```"):
            stripped = stripped[: -len("```")]
        stripped = stripped.strip()
        # Drop a leading language tag like "json".
        if stripped.startswith("json"):
            stripped = stripped[len("json"):].lstrip()

    # Find the first '{' and a matching closing '}'.
    start = stripped.find("{")
    if start == -1:
        raise ValueError("no '{' in claude response")
    depth = 0
    in_string = False
    escape = False
    for i in range(start, len(stripped)):
        ch = stripped[i]
        if in_string:
            if escape:
                escape = False
            elif ch == "\\":
                escape = True
            elif ch == '"':
                in_string = False
            continue
        if ch == '"':
            in_string = True
        elif ch == "{":
            depth += 1
        elif ch == "}":
            depth -= 1
            if depth == 0:
                return stripped[start : i + 1]
    raise ValueError("unbalanced braces in claude response")


def main() -> int:
    invocation_id = f"{int(time.time())}-{uuid.uuid4().hex[:8]}"
    envelope_text = sys.stdin.read()
    log_event(invocation_id, "01-envelope.json", envelope_text)

    try:
        envelope = json.loads(envelope_text)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"shim: stdin is not JSON: {exc}\n")
        return 2

    prompt_text = envelope.get("prompt", "")
    context = envelope.get("context") or {}
    surface_map = context.get("surface_map") or {}
    prior_errors = context.get("prior_errors") or []
    expected = envelope.get("expected_output") or {}

    # User message: prompt + raw envelope context (surface_map +
    # prior_errors + schema/max_steps) so the model has everything it
    # needs to obey §8.1.
    user_message_parts = [
        f"PROMPT:\n{prompt_text}",
        "",
        f"SURFACE_MAP (only paths allowed in plan.steps[].paths):",
        json.dumps(surface_map, indent=2, sort_keys=True),
        "",
        f"EXPECTED_OUTPUT.schema = {expected.get('schema', 'ao2.sdd-plan-candidate.v1')}",
        f"EXPECTED_OUTPUT.max_steps = {expected.get('max_steps', 25)}",
    ]
    if prior_errors:
        user_message_parts.extend(
            [
                "",
                "PRIOR_ERRORS (your previous attempt was rejected — fix every one):",
                json.dumps(prior_errors, indent=2),
            ]
        )
    user_message_parts.extend(
        [
            "",
            "Emit ONLY the candidate JSON object. No prose, no fences.",
        ]
    )
    user_message = "\n".join(user_message_parts)

    log_event(invocation_id, "02-user-message.txt", user_message)

    if not Path(REAL_CLAUDE).exists():
        # Fall back to searching PATH minus our shim directory.
        path_entries = [
            p for p in os.environ.get("PATH", "").split(":") if p and "sdd-planner-claude-shim" not in p
        ]
        candidate = None
        for p in path_entries:
            maybe = Path(p) / "claude"
            if maybe.exists() and os.access(maybe, os.X_OK):
                candidate = str(maybe)
                break
        if candidate is None:
            sys.stderr.write(f"shim: real claude binary not found (looked for {REAL_CLAUDE})\n")
            return 3
        real = candidate
    else:
        real = REAL_CLAUDE

    args = [
        real,
        "--print",
        "--output-format",
        "json",
        "--no-session-persistence",
        "--model",
        "claude-opus-4-7",
        "--system-prompt",
        SYSTEM_PROMPT,
        user_message,
    ]
    log_event(invocation_id, "03-claude-args.json", args)

    # Avoid PATH recursion (our shim is on PATH ahead of the real claude).
    child_env = dict(os.environ)
    child_env["PATH"] = ":".join(
        p for p in child_env.get("PATH", "").split(":") if p and "sdd-planner-claude-shim" not in p
    )

    proc = subprocess.run(
        args,
        capture_output=True,
        text=True,
        env=child_env,
    )
    log_event(invocation_id, "04-claude-stdout.txt", proc.stdout)
    log_event(invocation_id, "05-claude-stderr.txt", proc.stderr)
    log_event(invocation_id, "06-claude-exit.txt", str(proc.returncode))

    if proc.returncode != 0:
        sys.stderr.write(f"shim: claude exited {proc.returncode}\n")
        sys.stderr.write(proc.stderr)
        return 4

    try:
        wrapper = json.loads(proc.stdout)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"shim: claude stdout not JSON: {exc}\n")
        return 5

    if wrapper.get("is_error"):
        sys.stderr.write(f"shim: claude reported is_error=true: {wrapper.get('result')}\n")
        return 6

    result_text = wrapper.get("result", "")
    log_event(invocation_id, "07-result-text.txt", result_text)

    try:
        candidate_text = extract_json_object(result_text)
    except ValueError as exc:
        sys.stderr.write(f"shim: cannot extract JSON object from claude result: {exc}\n")
        sys.stderr.write(f"shim: raw result follows ----\n{result_text}\n----\n")
        return 7

    # Validate it parses as JSON before printing — the orchestrator will
    # also parse it, but failing here gives us a more local error.
    try:
        candidate = json.loads(candidate_text)
    except json.JSONDecodeError as exc:
        sys.stderr.write(f"shim: extracted text is not JSON: {exc}\n")
        sys.stderr.write(candidate_text + "\n")
        return 8

    log_event(invocation_id, "08-candidate.json", candidate)

    sys.stdout.write(candidate_text)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

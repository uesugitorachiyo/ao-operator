# AO Operator layered OpenClaw/AO profile.
# Each value may be changed to codex or claude. Providers must be OAuth CLI
# sessions, not API-key backed SDK calls.

FACTORY_V3_DEFAULT_PROVIDER=codex

# Control-plane defaults.
FACTORY_V3_PLANNER_PROVIDER=claude
FACTORY_V3_SPEC_FORGE_PROVIDER=claude
FACTORY_V3_RALPH_LOOP_PROVIDER=claude
FACTORY_V3_PLAN_HARDENER_PROVIDER=claude
FACTORY_V3_FACTORY_MANAGER_PROVIDER=codex
FACTORY_V3_IMPLEMENTER_PROVIDER=codex
FACTORY_V3_SLICE_REVIEWER_PROVIDER=claude
FACTORY_V3_INTEGRATOR_PROVIDER=codex
FACTORY_V3_EVALUATOR_CLOSER_PROVIDER=claude

# Exact AO example task overrides. These prove selection is per agent.
FACTORY_V3_OPENCLAW_SUBMIT_PROVIDER=claude
FACTORY_V3_FACTORY_V3_INTAKE_PROVIDER=claude
FACTORY_V3_FACTORY_V3_GATE_ROUTE_PROVIDER=claude
FACTORY_V3_AO_WORKER_CODEX_PROVIDER=codex
FACTORY_V3_AO_WORKER_CLAUDE_PROVIDER=claude
FACTORY_V3_FACTORY_V3_EVALUATE_PROVIDER=claude

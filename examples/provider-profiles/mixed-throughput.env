FACTORY_V3_DEFAULT_PROVIDER=codex

# This is only a recommended throughput profile, not an architecture
# requirement. Every value can be switched to codex or claude.
FACTORY_V3_PLANNER_PROVIDER=claude
FACTORY_V3_SPEC_FORGE_PROVIDER=claude
FACTORY_V3_RALPH_LOOP_PROVIDER=claude
FACTORY_V3_PLAN_HARDENER_PROVIDER=claude
FACTORY_V3_FACTORY_MANAGER_PROVIDER=codex
FACTORY_V3_IMPLEMENTER_PROVIDER=codex
FACTORY_V3_SLICE_REVIEWER_PROVIDER=claude
FACTORY_V3_INTEGRATOR_PROVIDER=codex
FACTORY_V3_EVALUATOR_CLOSER_PROVIDER=claude

# Exact fan-out agent overrides are supported when a topology names these ids.
FACTORY_V3_CONTRACT_FACTORY_PROVIDER=codex
FACTORY_V3_BACKEND_FACTORY_PROVIDER=codex
FACTORY_V3_FRONTEND_FACTORY_PROVIDER=codex
FACTORY_V3_QUALITY_FACTORY_PROVIDER=codex
FACTORY_V3_DOCS_FACTORY_PROVIDER=codex
FACTORY_V3_CONTRACT_REVIEWER_PROVIDER=claude
FACTORY_V3_BACKEND_REVIEWER_PROVIDER=claude

# Python
__pycache__/
*.pyc

# User-local provider routing (template lives in .env.example)
.env

# Per-run smoke-test scratch artifacts. Real factory runs write the same
# paths under non-`factoryv3-smoke-` slugs and remain trackable.
/docs/specs/factoryv3-smoke-*-spec.md
/docs/plans/factoryv3-smoke-*-plan.md
/docs/evaluations/factoryv3-smoke-*-evaluation.md
/run-artifacts/factoryv3-smoke-*/
/docs/evidence/factoryv3-smoke-*/
/docs/compliance/factoryv3-smoke-*/

# macOS / IDE detritus
.DS_Store
.idea/
.vscode/

# Local agent runtime settings
.claude/settings.json
.codex/config.toml

# gsd plugin checkpoint state (HANDOFF.json + scratch). Per dev-recipe SDD 08.
.planning/

# AO policy CLI scratch (approvals.db default path; per `ao-policy --help`).
/.ao/

# Hermes launchd runtime output. Scheduler templates are committed; live run
# payloads and logs are local operational state.
/run-artifacts/hermes-nightly-control-plane/latest-run/
/run-artifacts/hermes-nightly-scheduler/logs/
/run-artifacts/hermes-ao2-watchdog/

# Operator-local watchdog log rotations. Commit structured watchdog status and
# evidence artifacts, not local stdout/stderr rotations.
run-artifacts/hermes-governed-backend-control-plane/**/watchdog-loop*.log
run-artifacts/hermes-governed-backend-control-plane/**/watchdog-loop*.out
run-artifacts/hermes-governed-backend-control-plane/**/watchdog-loop*.out.*
run-artifacts/hermes-governed-backend-control-plane/**/watchdog-launchd-*.log

# Private knowledge source lives outside this repo.
llm-wiki/

# Remote Transfer v2 stress failed-live raw diagnostics. Commit sanitized
# summaries only; raw AO homes, full events, generated patches, and partial role
# docs can contain provider transcripts or diff-hygiene failures.
/docs/remote-transfer-v2/
/run-artifacts/remote-transfer-v2-stress/failure-snapshots/ao-home-*/
/run-artifacts/remote-transfer-v2-stress/patches/
/run-artifacts/remote-transfer-v2-stress/remote-transfer-v2-stress-ao-events.md

# Remote Transfer v2 bounded-live failed-run raw diagnostics. Accepted live
# evidence remains trackable under the slug; only raw failure AO homes are
# ignored here. Commit sanitized summaries only.
/run-artifacts/remote-transfer-v2-stress-live/failure-snapshots/ao-home-*
/run-artifacts/remote-transfer-v2-stress-live/failure-snapshots/ao-home-*/
.gstack/

# Hermes-AO2 watchdog operational runtime: launchd plist, tick/loop shell
# wrappers, stdout/err logs, and the runtime directory the watchdog writes
# to on every cycle (panel snapshots, nightly evidence exports, signed
# obligation gates, panel history, .sig sidecars). Live operational state
# only — not part of the project's tracked source.
/run-artifacts/hermes-governed-backend-control-plane/com.ao-operator.hermes-ao2-watchdog.plist
/run-artifacts/hermes-governed-backend-control-plane/watchdog-launchd-tick.sh
/run-artifacts/hermes-governed-backend-control-plane/watchdog-launchd.err.log
/run-artifacts/hermes-governed-backend-control-plane/watchdog-launchd.out.log
/run-artifacts/hermes-governed-backend-control-plane/watchdog-loop.sh
/run-artifacts/hermes-governed-backend-control-plane/watchdog-runtime/

# Hermes nightly AO2 evidence dump. Per-run signed artifacts are produced
# fresh each nightly cycle; commit sanitized status summaries elsewhere.
/run-artifacts/hermes-nightly-ao2/
